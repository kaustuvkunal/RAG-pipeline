
# --- Ollama Base URL ---
OLLAMA_SERVICE_URL=http://localhost:11434

# -------- Data Source --------
DOC_PATH=data/tesla-annual-reports
# DOC_PATH=data/tesla-annual-reports  ← Switch to folder when ready

# -------- Chunking Strategy & Size --------
CHUNK_STRATEGY=recursive
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# -------- Embedding Model Configuration --------
EMBEDDER_TYPE=ollama
EMBEDDING_MODEL=qwen3-embedding:0.6b
EMBEDDING_BASE_URL=http://localhost:11434

# -------- Vector Database --------
VECTOR_DB_TYPE=chroma # ← Change to chroma/qdrant/faiss  later if needed
QDRANT_URL=http://localhost:6333

# -------- LLM Configuration (Consolidated) --------
LLM_TYPE=ollama
LLM_MODEL=gemma4:e4b
LLM_BASE_URL=http://localhost:11434/v1  # ⚠️ Must include /v1 for LangChain compatibility
API_KEY=ollama

# -------- Search/Retrieval Strategy --------
SEARCH_STRATEGY=semantic
K=5

# --- Optional Chroma Settings (uncomment when using VECTOR_DB_TYPE=chroma) ---
CHROMA_COLLECTION_NAME=tesla_rag
CHROMA_PERSIST_DIRECTORY=./chroma_db


